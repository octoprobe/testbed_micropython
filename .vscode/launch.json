{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "mptest list",
            "type": "debugpy",
            "request": "launch",
            "module": "testbed.mptest.cli",
            "cwd": "${workspaceFolder}",
            "args": [
                // "--help",
                "list",
            ],
            "console": "integratedTerminal",
            "env": {
                "PYDEVD_DISABLE_FILE_VALIDATION": "1",
            },
            "justMyCode": false,
        },
        {
            "name": "mptest flash",
            "type": "debugpy",
            "request": "launch",
            "module": "testbed.mptest.cli",
            // "cwd": "${workspaceFolder}/git_cache/micropython_firmware_e8452d67a60e9613af4e0de0bafed1b8",
            "cwd": "${workspaceFolder}/git_cache/micropython_tests_e8452d67a60e9613af4e0de0bafed1b8/",
            "args": [
                "flash",
                // "--last-variant",
            ],
            "console": "integratedTerminal",
            "env": {
                "PYDEVD_DISABLE_FILE_VALIDATION": "1",
            },
            "justMyCode": false,
        },
        {
            "name": "mptest test",
            "type": "debugpy",
            "request": "launch",
            "module": "testbed.mptest.cli",
            "cwd": "${workspaceFolder}",
            "args": [
                // "--help",
                "test",
                "--micropython-tests=https://github.com/micropython/micropython.git@master",
                "--firmware-build=https://github.com/micropython/micropython.git@v1.24.1",
                // "--firmware-build=https://github.com/micropython/micropython.git@master",
                // "--flash-skip",
                // "--no-multiprocessing",
                // "--only-test=RUN-NONE",
                // "--only-test=RUN-TESTS_BASICS",
                "--only-test=RUN-TESTS_EXTMOD_HARDWARE",
                // "--only-variant=LOLIN_D1_MINI-FLASH_512K",
                // "--only-variant=RPI_PICO2",
                // "--firmware-build-git=https://github.com/micropython/micropython.git@master",
                // "--firmware-build-git=https://github.com/micropython/micropython.git@master",
                // "--only-test=RUN-TESTS_EXTMOD_HARDWARE",
                // "RPI_PICO",
                // "ESP8266_GENERIC",
            ],
            "console": "integratedTerminal",
            "env": {
                "PYDEVD_DISABLE_FILE_VALIDATION": "1",
            },
            "justMyCode": false,
            "subProcess": false,
        },
        {
            "name": "pytest --firmware-build-url",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "args": [
                // "--collect-only",
                // "-q",
                "-s",
                "-v",
                // "--firmware-build-url=https://github.com/dpgeorge/micropython.git@rp2-add-rp2350",
                "run",
                "--firmware-build-url=https://github.com/micropython/micropython.git@master",
                "tests/test_simple.py::test_i2c",
            ],
            "console": "integratedTerminal",
            "env": {
                "PYDEVD_DISABLE_FILE_VALIDATION": "1"
            },
            "justMyCode": false,
        },
        {
            "name": "pytest --firmware-build-url LOLIN_C3_MINI",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "args": [
                // "--collect-only",
                // "-q",
                "-s",
                "-v",
                "--git-micropython-tests=https://github.com/dpgeorge/micropython.git@tests-full-test-runner",
                "--firmware-build-url=https://github.com/micropython/micropython.git@v1.24.1",
                // "--firmware-build-url=https://github.com/dpgeorge/micropython.git@rp2-add-rp2350",
                "tests/micropython_repo/test_run.py::test_extmod_hardware",
            ],
            "console": "integratedTerminal",
            "env": {
                "PYDEVD_DISABLE_FILE_VALIDATION": "1"
            },
            "justMyCode": false,
        },
        {
            "name": "Ruff",
            "type": "debugpy",
            "request": "launch",
            "module": "ruff",
            "cwd": "${workspaceFolder}",
            "args": [
                "check",
                "--config",
                "pyproject.toml",
                "--fix",
            ],
            "console": "integratedTerminal",
        },
        {
            "name": "Mypy",
            "type": "debugpy",
            "request": "launch",
            "module": "mypy",
            "cwd": "${workspaceFolder}",
            "args": [
                "--config-file",
                "pyproject.toml",
                "src",
                "tests",
            ],
            "console": "integratedTerminal",
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
        },
        {
            "name": "Python: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}",
            "justMyCode": false,
        }
    ]
}